# Volcengine Ark API Key（必填）
# 获取地址：https://console.volcengine.com/ark
ARK_API_KEY=your-volcengine-ark-api-key

# 本地任务缓存目录（可选）
# 默认 ~/.cache/seedance-mcp
# 改的话用绝对路径：SEEDANCE_CACHE_DIR=/path/to/cache
# SEEDANCE_CACHE_DIR=

# uguu.se 图床（无需 key · 匿名上传）
# 替代原 chevereto（2026-06-11 spike 006 改造）
# 上传 endpoint: https://uguu.se/upload.php
# 返回: https://n.uguu.se/<id>.jpg 直链（永久有效，无需鉴权）
# 代码内置自动选择，**不要**手动设

# 网络代理（可选）
# 公司代理对 ark.cn-beijing.volces.com 友好
# 但 uguu.se 走代理会 SSL EOF（详见 TROUBLESHOOTING.md）
# 留空 = 直连
# HTTPS_PROXY=http://127.0.0.1:7897
# NO_PROXY=uguu.se,n.uguu.se,o.uguu.se
